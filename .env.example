# =============================================================
# FinFlow — Variáveis de ambiente (.env.local)
# =============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local — ele está no .gitignore.
# =============================================================

# ── Frontend (Vite expõe via import.meta.env.VITE_*) ──────────
# Onde encontrar: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Places API (busca de empresa em contatos PJ)
# Setup:
#   1. https://console.cloud.google.com → crie um projeto
#   2. APIs & Services → Library → "Places API (New)" → Enable
#   3. APIs & Services → Credentials → Create API key
#   4. Edite a chave: Application restrictions → HTTP referrers
#      Adicione: localhost:*  *.vercel.app  seudominio.com.br
#   5. Cole abaixo. No Vercel: Settings → Environment Variables
#
# Custos: $200/mês de créditos gratuitos (~17 mil buscas/mês).
VITE_GOOGLE_PLACES_KEY=

# ── Scripts Node (NÃO expostos ao browser) ────────────────────
# Usados por scripts/*.mjs (seeds, migrações, queries diretas)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
